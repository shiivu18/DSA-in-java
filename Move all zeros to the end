package Arrays;

public class MoveZeros {

	public static void main(String[] args) {
		
		int[] arr = {78,0,8,0,};
		
		movez(arr);
		
		for(int num :arr) {
			
			System.out.println("" +num);
		}
		
	
			
			
		}
	static void movez(int[] arr) {
		int j=0;
		
		for(int i=0;i<arr.length;i++) {
			if(arr[i]!=0) {
			int temp =arr[i];
			arr[i]=arr[j];
			arr[j]=temp;
			j++;
			
			
			
					
		}
		
		



	}

}
}
